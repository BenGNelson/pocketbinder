# PocketBinder configuration. Copy to .env and adjust. No secrets are committed.

# --- Ports (host side; offset so it coexists with other apps) ---
# API_PORT=8010
# FRONTEND_PORT=8088

# --- Catalog ---
# A local clone of the public pokemon-tcg-data dataset (the whole English catalog
# as static JSON). Clone it once:
#   git clone https://github.com/PokemonTCG/pokemon-tcg-data /path/to/pokemon-tcg-data
# then point CARD_DATA_SRC at it (mounted read-only at /card-data). Unset = a tiny
# committed example (a couple of sets). `git pull` it occasionally for new sets.
# CARD_DATA_SRC=/path/to/pokemon-tcg-data

# Catalog indexer (parses the clone into SQLite). On by default; re-scans daily.
# CARDS_INDEX_ENABLED=true
# CARDS_INDEX_INTERVAL=86400

# --- Market value (optional) ---
# A free pokemontcg.io API key (dev.pokemontcg.io). Set it and the indexer
# refreshes TCGplayer/Cardmarket prices for the cards you OWN (a bounded set) on
# its daily cadence, so collection value stays <=1 day fresh. Unset = no prices.
# POKEMONTCG_API_KEY=

# --- Fully-offline images (optional) ---
# If you download the full-res card-image dump, uncomment the /card-images mount
# in docker-compose.yml and set CARDS_DIR to its in-container path.
# CARDS_DIR=/card-images

# CORS: leave empty (the SPA is same-origin behind nginx). Only set if a separate
# browser app must call the API cross-origin.
# CORS_ALLOW_ORIGINS=
